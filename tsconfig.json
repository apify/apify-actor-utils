{
    "extends": "@apify/tsconfig",
    "compilerOptions": {
        "declaration": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "ES2022",
        "outDir": "dist",
        "noUnusedLocals": false,
        "strict": true,
        "esModuleInterop": true,
        "lib": ["DOM", "es2021"],
        "skipLibCheck": true,
        "types": ["node"],
        "importHelpers": false
    },
    "include": ["./index.ts", "src/**/*.ts", "test/**/*.ts"]
}
